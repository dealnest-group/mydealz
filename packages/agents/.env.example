SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# production = Groq API | local = Ollama
AGENT_ENV=production

GROQ_API_KEY=your-groq-api-key-here

# AWIN Affiliate Network — get from app.awin.com → Account → API
AWIN_API_KEY=your-awin-api-key-here

# ScraperAPI — needed for retailers that block direct HTTP (Aldi, Lidl, etc.)
# Free tier: 5,000 calls/month — https://scraperapi.com
SCRAPERAPI_KEY=your-scraperapi-key-here

# Only needed when AGENT_ENV=production and you want embeddings
# HF_API_KEY=your-hf-key-here
